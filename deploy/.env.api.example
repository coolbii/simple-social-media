SPRING_PROFILES_ACTIVE=prod
API_PORT=8080
API_LOG_LEVEL=INFO
DB_MIGRATION_ENABLED=true

# RDS
MYSQL_HOST=your-rds-endpoint.rds.amazonaws.com
MYSQL_PORT=3306
MYSQL_DATABASE=simple_social_media
MYSQL_USER=social_user
MYSQL_PASSWORD=replace_me

# Auth cookie
AUTH_SESSION_COOKIE_NAME=social.sid
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAME_SITE=Lax
AUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_ACCESS_TOKEN_SECRET=replace_me_with_long_random_secret

# SMS provider
AUTH_SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=replace_me
TWILIO_AUTH_TOKEN=replace_me
TWILIO_VERIFY_SERVICE_SID=replace_me
TWILIO_VERIFY_LOCALE=zh-HK

# S3
# On EC2, prefer IAM role credentials (no AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY needed).
AWS_REGION=ap-southeast-2
AWS_S3_BUCKET=replace_me
AWS_S3_SIGNED_GET_EXPIRE_SECONDS=3600
APP_STORAGE_MAX_FILE_SIZE_BYTES=1048576
APP_STORAGE_MAX_FILE_SIZE=2MB
APP_STORAGE_MAX_REQUEST_SIZE=2MB
