AUTH_SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_VERIFY_SERVICE_SID=your_twilio_verify_service_sid
TWILIO_VERIFY_LOCALE=zh-HK
# Keep empty in local dev to use Vite proxy (/api) and avoid loopback cookie mismatch.
VITE_API_BASE_URL=

# S3 upload settings (recommended for production)
AWS_REGION=ap-northeast-1
AWS_S3_BUCKET=your_bucket_name
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_S3_SIGNED_GET_EXPIRE_SECONDS=3600
APP_STORAGE_MAX_FILE_SIZE_BYTES=1048576
APP_STORAGE_MAX_FILE_SIZE=2MB
APP_STORAGE_MAX_REQUEST_SIZE=2MB
